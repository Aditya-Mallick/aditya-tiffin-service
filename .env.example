# Copy this file to ".env.local" and fill in the two values from your
# Supabase project (Project Settings → API). Then restart the dev server.
#
# .env.local is git-ignored, so these values are NOT committed.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: the domain used to turn a mobile number into an internal login
# email. Leave as-is unless you have a reason to change it.
VITE_LOGIN_EMAIL_DOMAIN=tiffin.local
